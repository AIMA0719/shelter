# =============================================================================
# Shelter — 환경변수 예시 파일
# 실제 운영 시 이 파일을 .env 로 복사하고 각 값을 채워 넣으세요.
# .env 파일은 절대 git 에 커밋하지 마세요.
# =============================================================================

# -----------------------------------------------------------------------------
# [필수] 건물 데이터 — GeoJSON 경로 (PostGIS 미사용 시)
# GeoJSON 파일 경로(절대 경로 또는 컨테이너 내 경로).
# SHELTER_DB_DSN 를 설정한 경우 이 값은 무시됩니다.
# -----------------------------------------------------------------------------
SHELTER_BUILDINGS_GEOJSON=/data/seoul_buildings.geojson

# -----------------------------------------------------------------------------
# [필수] POI 데이터 — GeoJSON 경로 (PostGIS 미사용 시)
# 지하철 입구, 버스 정류장 등 관심 지점 GeoJSON.
# -----------------------------------------------------------------------------
SHELTER_POIS_GEOJSON=/data/seoul_pois.geojson

# -----------------------------------------------------------------------------
# [선택] 보행 네트워크 GeoJSON (OSM LineString 그래프)
# 지정하고 파일이 존재하면 OSM 기반 경로 탐색을 사용합니다.
# 미지정 시 격자(grid) 폴백을 사용합니다.
# -----------------------------------------------------------------------------
SHELTER_WALK_NETWORK_GEOJSON=

# -----------------------------------------------------------------------------
# [선택] PostGIS DSN — 서울 전역 건물/POI 데이터베이스
# 지정하면 GeoJSON 파일 대신 PostGIS 에서 데이터를 조회합니다(권장).
# 로컬 개발: docker compose 사용 시 자동으로 주입됩니다.
# -----------------------------------------------------------------------------
SHELTER_DB_DSN=

# -----------------------------------------------------------------------------
# [선택] 기상청(KMA) API 서비스 키
# 지정하면 실제 기상 데이터를 사용합니다. 미지정 시 stub 을 사용합니다.
# 발급: https://www.data.go.kr/
# -----------------------------------------------------------------------------
SHELTER_KMA_SERVICE_KEY=

# -----------------------------------------------------------------------------
# [선택] 카카오 REST API 키 — 경로 탐색 제공자로 'kakao' 선택 시 필요
# SHELTER_DIRECTIONS_PROVIDER=kakao 로 설정할 때만 필요합니다.
# -----------------------------------------------------------------------------
SHELTER_KAKAO_REST_API_KEY=

# -----------------------------------------------------------------------------
# [선택] 경로 탐색 제공자
# 'straight' (오프라인, 기본값) | 'kakao' (카카오 모빌리티 API)
# -----------------------------------------------------------------------------
SHELTER_DIRECTIONS_PROVIDER=straight

# -----------------------------------------------------------------------------
# [선택] 건물 조회 시 경로 bbox 확장 거리 (미터)
# 그림자가 bbox 밖 건물에서 드리워질 수 있으므로 여유 값을 줍니다.
# 기본값: 300
# -----------------------------------------------------------------------------
SHELTER_BBOX_MARGIN_M=300

# -----------------------------------------------------------------------------
# [선택] LRU 캐시 최대 항목 수
# 기본값: 512
# -----------------------------------------------------------------------------
SHELTER_CACHE_MAX_ENTRIES=512

# -----------------------------------------------------------------------------
# [선택] IP 당 분당 요청 한도 (Rate Limiting)
# 0 으로 설정하면 비활성화됩니다.
# 기본값: 600
# -----------------------------------------------------------------------------
SHELTER_RATE_LIMIT_PER_MIN=600

# =============================================================================
# Android 앱 전용 키 (backend 와 무관 — local.properties 에 기재)
# =============================================================================

# [필수 — 앱] 네이버 지도 SDK 클라이언트 ID
# Android 앱의 local.properties 에 NCP_KEY_ID=<값> 으로 설정하세요.
# 이 파일에서는 참고용으로만 기재합니다. backend 컨테이너에는 불필요합니다.
# NCP_KEY_ID=
